{
  "tasks": {
    "dev": "deno run -A --env-file=.env --unstable-detect-cjs --watch index.tsx",
    "test": "deno test -A --no-check --unstable-detect-cjs test/",
    "test:unit": "deno test -A --no-check --unstable-detect-cjs test/lib/ test/middleware/",
    "test:models": "deno test -A --no-check --unstable-detect-cjs test/models/",
    "test:routes": "deno test -A --no-check --unstable-detect-cjs test/routes/"
  },
  "imports": {
    "npm:hono": "npm:hono@^4",
    "npm:hono/cors": "npm:hono@^4/cors",
    "npm:hono/logger": "npm:hono@^4/logger",
    "npm:mongoose": "npm:mongoose@^8",
    "npm:bcryptjs": "npm:bcryptjs@^2.4.3",
    "npm:jsonwebtoken": "npm:jsonwebtoken@^9",
    "npm:xlsx": "npm:xlsx@^0.18",
    "npm:mongodb-memory-server": "npm:mongodb-memory-server@^10"
  },
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "lib": ["deno.window"]
  },
  "allowScripts": ["npm:mongodb-memory-server@10.4.3", "npm:protobufjs@6.11.5", "npm:sharp@0.32.6"]
}